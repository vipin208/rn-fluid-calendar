{
  "name": "rn-fluid-calendar",
  "version": "1.0.0",
  "description": "A modern, highly customizable React Native calendar with dark/light mode, 5 animation types, flexible marking, and full developer control over styles, fonts, and layout.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "build": "bob build",
    "prepare": "bob build",
    "typescript": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\""
  },
  "keywords": [
    "react-native",
    "calendar",
    "date-picker",
    "dark-mode",
    "animation",
    "customizable",
    "modern",
    "ios",
    "android",
    "typescript",
    "marking",
    "multi-select",
    "period",
    "dot"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vipin208/rn-fluid-calendar.git"
  },
  "author": "Vipin Jaiswal <vipin208@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vipin208/rn-fluid-calendar/issues"
  },
  "homepage": "https://github.com/vipin208/rn-fluid-calendar#readme",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.68.0"
  },
  "devDependencies": {
    "@react-native-community/eslint-config": "^3.2.0",
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.72.0",
    "react-native-builder-bob": "^0.21.3",
    "typescript": "^5.0.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
